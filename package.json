{
  "name": "itcamp-allcamp",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "@types/bun": "^1.3.4",
      "next-themes": "^0.4.6",
      "@libsql/client": "0.15.15",
      "libsql": "0.5.22",
      "@types/react-dom": "^19.2.3"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @itcamp-allcamp/db db:push",
    "db:studio": "turbo -F @itcamp-allcamp/db db:studio",
    "db:generate": "turbo -F @itcamp-allcamp/db db:generate",
    "db:migrate": "turbo -F @itcamp-allcamp/db db:migrate",
    "db:local": "turbo -F @itcamp-allcamp/db db:local"
  },
  "dependencies": {
    "@itcamp-allcamp/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@itcamp-allcamp/config": "workspace:*",
    "@types/bun": "catalog:",
    "turbo": "^2.8.12",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.9"
}
